{
  "name": "swiftdrop",
  "version": "1.0.0",
  "main": "app/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.swiftdrop.app",
    "productName": "SwiftDrop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "app/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0"
  }
}
